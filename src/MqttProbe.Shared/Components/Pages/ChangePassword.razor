@page "/change-password"
@using MqttProbe.Services.Configuration
@using MqttProbe.Services.Security
@attribute [Authorize(Roles = AppRoles.Admin)]
@inject IUserAuthService UserAuthService
@inject ISettingsStore SettingsStore
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Change Password</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="0" Class="pa-6 app-chrome-panel">
        <MudText Typo="Typo.h5" Class="mb-4">Change Password</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
            Use at least 12 characters with a mix of upper/lower letters, numbers, and symbols.
        </MudText>

        @if (_errorMessage is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
        }

        <MudTextField @bind-Value="_currentPassword"
                      Label="Current Password"
                      InputType="@_currentPasswordInputType"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_currentPasswordIcon"
                      OnAdornmentClick="@ToggleCurrentPassword"
                      AdornmentAriaLabel="Show current password"
                      Variant="Variant.Outlined"
                      Class="mb-3"
                      Immediate="true" />

        <MudTextField @bind-Value="_newPassword"
                      Label="New Password"
                      InputType="@_newPasswordInputType"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_newPasswordIcon"
                      OnAdornmentClick="@ToggleNewPassword"
                      AdornmentAriaLabel="Show new password"
                      Variant="Variant.Outlined"
                      HelperText="Avoid reused credentials and predictable words."
                      Class="mb-3"
                      Immediate="true" />

        <MudTextField @bind-Value="_confirmPassword"
                      Label="Confirm New Password"
                      InputType="@_confirmPasswordInputType"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_confirmPasswordIcon"
                      OnAdornmentClick="@ToggleConfirmPassword"
                      AdornmentAriaLabel="Show confirm password"
                      Variant="Variant.Outlined"
                      Class="mb-4"
                      Immediate="true" />

        <MudStack Row="true" Spacing="2">
            <AppPrimaryButton
                       MinWidth="true"
                       OnClick="Submit"
                        Disabled="_saving">
                @(_saving ? "Saving…" : "Save Password")
            </AppPrimaryButton>
            <AppTertiaryButton
                       MinWidth="true"
                        OnClick="@(() => NavigationManager.NavigateTo("/?tab=settings"))">
                Cancel
            </AppTertiaryButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private const int MinPasswordLength = 12;

    internal string _currentPassword = string.Empty;
    internal string _newPassword = string.Empty;
    internal string _confirmPassword = string.Empty;
    private string? _errorMessage;
    private bool _saving;
    private InputType _currentPasswordInputType = InputType.Password;
    private InputType _newPasswordInputType = InputType.Password;
    private InputType _confirmPasswordInputType = InputType.Password;
    private string _currentPasswordIcon = LucideIcons.EyeOff;
    private string _newPasswordIcon = LucideIcons.EyeOff;
    private string _confirmPasswordIcon = LucideIcons.EyeOff;

    internal async Task Submit()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            _errorMessage = "New password cannot be empty.";
            return;
        }

        if (_newPassword.Length < MinPasswordLength)
        {
            _errorMessage = $"New password must be at least {MinPasswordLength} characters.";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _errorMessage = "Passwords do not match.";
            return;
        }

        _saving = true;

        var username = SettingsStore.Config.Auth.Username;
        var result = await UserAuthService.ChangePasswordAsync(username, _currentPassword, _newPassword);

        _saving = false;

        if (!result.Succeeded)
        {
            _errorMessage = result.Error ?? "Current password is incorrect.";
            return;
        }

        _currentPassword = string.Empty;
        _newPassword = string.Empty;
        _confirmPassword = string.Empty;
        Snackbar.Add("Password updated successfully.", Severity.Success);
        NavigationManager.NavigateTo("/?tab=settings");
    }

    private void ToggleCurrentPassword()
    {
        (_currentPasswordInputType, _currentPasswordIcon) = TogglePasswordState(_currentPasswordInputType);
    }

    private void ToggleNewPassword()
    {
        (_newPasswordInputType, _newPasswordIcon) = TogglePasswordState(_newPasswordInputType);
    }

    private void ToggleConfirmPassword()
    {
        (_confirmPasswordInputType, _confirmPasswordIcon) = TogglePasswordState(_confirmPasswordInputType);
    }

    private static (InputType, string) TogglePasswordState(InputType current) =>
        current == InputType.Password
            ? (InputType.Text, LucideIcons.Eye)
            : (InputType.Password, LucideIcons.EyeOff);
}
