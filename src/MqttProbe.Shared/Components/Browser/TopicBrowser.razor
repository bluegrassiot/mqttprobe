@inject IMessageStoreManager MessageStoreManagerService
@inject ILogger<TopicBrowser> Logger
@using Microsoft.Extensions.Logging
@implements IAsyncDisposable

<MudPaper Elevation="1" Class="pa-2 app-chrome-panel" Style="flex:1 1 auto; min-height:0; display:flex; flex-direction:column; overflow:hidden; box-sizing:border-box;">
    <div class="topic-header-row">
        <MudIcon Icon="@LucideIcons.Layers" Size="Size.Small" Color="Color.Primary"/>
        <MudText Typo="Typo.subtitle2" Style="font-weight:600">Topics</MudText>
        @if (MessageStoreManagerService.MessageStores.Any())
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                     Style="height:20px; font-size:0.7rem; padding:0 6px;">
                @MessageStoreManagerService.MessageStores.Count
            </MudChip>
        }
    </div>
    <div class="topic-filter-wrap">
        <MudTextField @bind-Value="_searchFilter" @bind-Value:after="OnSearchChanged"
                      Placeholder="Filter&hellip;"
                      Adornment="Adornment.Start" AdornmentIcon="@LucideIcons.Search"
                      Immediate="true" Clearable="true" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="topic-filter-field"/>
    </div>
    <div class="topic-tree-wrap" style="flex:1 1 auto; min-height:0; overflow:auto;">
        <MudToolBar Class="pa-0 mb-1" Style="gap:4px;">
            <MudIconButton Icon="@LucideIcons.Maximize2" Size="Size.Small" title="Expand all" OnClick="ExpandAll"/>
            <MudIconButton Icon="@LucideIcons.Minimize2" Size="Size.Small" title="Collapse all" OnClick="CollapseAll"/>
            <span class="topic-stat-legend">T = topics · M = messages</span>
        </MudToolBar>
        @if (_visibleRows.Count > 0)
        {
            <Virtualize Items="@_visibleRows" Context="row" ItemSize="36">
                <TopicTreeRow Row="row" IsSelected="@(row.FullPath == _selectedFullPath)" OnExpandToggled="ToggleExpand" OnSelected="OnRowSelected"/>
            </Virtualize>
        }
        else if (MessageStoreManagerService.MessageStores.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-3">
                No topics match "@_searchFilter"
            </MudText>
        }
        else
        {
            <div class="d-flex flex-column align-center pa-6 topic-empty">
                <MudIcon Icon="@LucideIcons.Inbox" Size="Size.Large" Color="Color.Secondary"/>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">No messages received yet</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Press play to start capturing</MudText>
            </div>
        }
    </div>
</MudPaper>

@code {
    private string? _searchFilter;
    private Timer? _updateTimer;
    private bool _disposed;
    private long _lastVersion;
    private List<TopicTreeRowModel> _visibleRows = [];
    private HashSet<string> _expandedPaths = [];
    private bool _hasFilter;
    private string? _selectedFullPath;

    protected override void OnInitialized()
    {
        BuildVisibleRows();
        _updateTimer = new Timer(_ =>
        {
            if (_disposed) return;
            var version = MessageStoreManagerService.GetVersion();
            if (version == _lastVersion) return;
            _lastVersion = version;
#pragma warning disable CS4014
            RefreshAsync();
#pragma warning restore CS4014
        }, null, 0, 1_000);
    }

    private async Task RefreshAsync()
    {
        BuildVisibleRows();
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) when (_disposed) { }
        catch (Exception ex) { Logger.LogWarning(ex, "TopicBrowser refresh render failed"); }
    }

    private void BuildVisibleRows()
    {
        _visibleRows = [];
        _hasFilter = !string.IsNullOrWhiteSpace(_searchFilter);

        // Keep visual selection consistent with manager state.
        var managerSelection = MessageStoreManagerService.SelectedMessageStore;
        _selectedFullPath = managerSelection is null
            ? null
            : managerSelection.FullTopic ?? managerSelection.Topic;

        foreach (var kvp in MessageStoreManagerService.MessageStores
                     .OrderBy(s => s.Key, NaturalStringComparer.Instance))
        {
            AppendRows(kvp.Value, _hasFilter);
        }
    }

    private void AppendRows(MessageStore store, bool hasFilter)
    {
        var path = store.FullTopic ?? store.Topic ?? "";
        var isExpanded = _expandedPaths.Contains(path);
        var matches = hasFilter && MatchesFilter(store, _searchFilter!);

        if (hasFilter && !matches && !HasAnyMatchingDescendant(store))
            return;

        _visibleRows.Add(new TopicTreeRowModel(
            Store: store,
            FullPath: path,
            DisplayName: store.Topic ?? "",
            Depth: path.Count(c => c == '/'),
            HasChildren: store.SubTopics?.Count > 0,
            TopicCount: store.TopicCount,
            MessageCount: store.MessageCount,
            IsExpanded: isExpanded || (hasFilter && matches),
            IsValueBearer: store.Messages is { IsEmpty: false }
        ));

        if (store.SubTopics is { Count: > 0 } && (isExpanded || hasFilter))
        {
            foreach (var child in store.SubTopics.Values
                         .OrderBy(s => s.Topic, NaturalStringComparer.Instance))
            {
                AppendRows(child, hasFilter);
            }
        }
    }

    private static bool MatchesFilter(MessageStore store, string filter) =>
        (store.Topic?.Contains(filter, StringComparison.OrdinalIgnoreCase) == true)
        || (store.SubTopics?.Values.Any(s => MatchesFilter(s, filter)) ?? false);

    private bool HasAnyMatchingDescendant(MessageStore store) =>
        store.SubTopics?.Values.Any(s => MatchesFilter(s, _searchFilter!)) ?? false;

    private void OnSearchChanged()
    {
        _selectedFullPath = null;
        MessageStoreManagerService.SelectedMessageStore = null;
        BuildVisibleRows();
        StateHasChanged();
    }

    private void OnRowSelected(string path)
    {
        _selectedFullPath = path;
        BuildVisibleRows();
        StateHasChanged();
    }

    private async Task ToggleExpand(string path)
    {
        if (_expandedPaths.Contains(path))
            _expandedPaths.Remove(path);
        else
            _expandedPaths.Add(path);
        BuildVisibleRows();
        StateHasChanged();
    }

    private void ExpandAll()
    {
        foreach (var kvp in MessageStoreManagerService.MessageStores)
            ExpandAllDescendants(kvp.Value);
        BuildVisibleRows();
        StateHasChanged();
    }

    private void ExpandAllDescendants(MessageStore store)
    {
        if (store.FullTopic != null)
            _expandedPaths.Add(store.FullTopic);
        if (store.SubTopics != null)
            foreach (var child in store.SubTopics.Values)
                ExpandAllDescendants(child);
    }

    private void CollapseAll()
    {
        _expandedPaths.Clear();
        BuildVisibleRows();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_updateTimer != null)
            await _updateTimer.DisposeAsync();
    }
}
