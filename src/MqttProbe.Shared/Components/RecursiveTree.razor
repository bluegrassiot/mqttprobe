@if (MessageStore.SubTopics?.Count > 0)
{
    <MudTreeViewItem Value="@MessageStore"
                     Text="@MessageStore.Topic"
                     Expanded="@(Level == 0 && ExpandFirstLevel)"
                     Icon="@LucideIcons.Folder"
                     IconColor="@FolderColor"
                     Class="@($"topic-depth-{Math.Min(Level, 4)}")">
        @foreach (var subtopic in VisibleSubTopics)
        {
            <RecursiveTree @key="@subtopic.FullTopic" MessageStore="@subtopic" Filter="@Filter" Level="@(Level + 1)" ExpandFirstLevel="@ExpandFirstLevel"/>
        }
    </MudTreeViewItem>
}
else
{
    var count = MessageStore.Messages?.Count ?? 0;
    <MudTreeViewItem Value="@MessageStore"
                     Text="@MessageStore.Topic"
                     Icon="@LucideIcons.Circle"
                     IconColor="Color.Secondary"
                     Class="@($"topic-depth-{Math.Min(Level, 4)}")"
                     EndText="@($"{count:N0}")"
                     EndTextTypo="Typo.caption"/>
}

@code {
    [Parameter] public required MessageStore MessageStore { get; set; }
    [Parameter] public string? Filter { get; set; }
    [Parameter] public int Level { get; set; }
    [Parameter] public bool ExpandFirstLevel { get; set; } = true;

    private List<MessageStore> _sortedSubTopics = [];
    private MessageStore? _lastMessageStore;
    private int _lastSubTopicCount;
    private Color FolderColor => Level switch
    {
        0 => Color.Primary,
        1 => Color.Info,
        _ => Color.Secondary
    };

    private IEnumerable<MessageStore> VisibleSubTopics =>
        string.IsNullOrWhiteSpace(Filter)
            ? _sortedSubTopics
            : _sortedSubTopics.Where(s => Matches(s, Filter));

    protected override void OnParametersSet()
    {
        var count = MessageStore.SubTopics?.Count ?? 0;
        if (ReferenceEquals(MessageStore, _lastMessageStore) && count == _lastSubTopicCount) return;
        _lastMessageStore = MessageStore;
        _lastSubTopicCount = count;
        _sortedSubTopics = MessageStore.SubTopics?.Values.OrderBy(t => t.Topic, NaturalStringComparer.Instance).ToList() ?? [];
    }

    internal static bool Matches(MessageStore store, string filter) =>
        (store.Topic?.Contains(filter, StringComparison.OrdinalIgnoreCase) == true) ||
        (store.SubTopics?.Values.Any(s => Matches(s, filter)) ?? false);
}
