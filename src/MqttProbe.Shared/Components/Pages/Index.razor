@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using MQTTnet.Extensions.ManagedClient
@using MqttProbe.Services.Configuration
@using MqttProbe.Services.Mqtt
@attribute [Authorize]
@implements IDisposable
@inject IManagedMqttClient MqttClient
@inject IConnectionSessionLifecycle SessionLifecycle
@inject IMessageStoreManager MessageStoreManager
@inject ISettingsStore SettingsStore
@inject ISessionState SessionState
@inject ISubscriptionManager SubscriptionManager
@inject IEmulationService EmulationService
@inject ISparkplugTopologyService TopologyService
@inject NavigationManager NavigationManager

<PageTitle>MQTTProbe</PageTitle>

<nav class="mobile-primary-nav" aria-label="Primary navigation">
    @foreach (var dest in _destinations.Where(d => d.IsMobilePrimary && d.IsVisible()))
    {
        @if (dest.RequiresOperatorRole)
        {
            <AuthorizeView Roles="Admin,Operator">
                <Authorized>
                    <button class="mobile-nav-btn @(IsSlugActive(dest.Slug) ? "active" : "")"
                            @onclick="() => OnDestinationSelected(dest)"
                            aria-current="@(IsSlugActive(dest.Slug) ? "page" : null)">
                        <MudIcon Icon="@dest.Icon" Size="Size.Medium" />
                        <span>@dest.Label()</span>
                    </button>
                </Authorized>
            </AuthorizeView>
        }
        else
        {
            <button class="mobile-nav-btn @(IsSlugActive(dest.Slug) ? "active" : "")"
                    @onclick="() => OnDestinationSelected(dest)"
                    aria-current="@(IsSlugActive(dest.Slug) ? "page" : null)">
                <MudIcon Icon="@dest.Icon" Size="Size.Medium" />
                <span>@dest.Label()</span>
            </button>
        }
    }

    @{
        var moreItems = _destinations.Where(d => !d.IsMobilePrimary && d.IsVisible()).ToList();
    }
    @if (moreItems.Count > 0)
    {
        @* Right-aligned so the popover never extends past the right viewport
           edge — a centered anchor overflows horizontally on phones, which
           makes mobile browsers zoom out and the fixed nav bar vanish. *@
        <MudMenu Icon="@LucideIcons.MoreVertical" Size="Size.Medium"
                 AnchorOrigin="Origin.TopRight" TransformOrigin="Origin.BottomRight"
                 Class="mobile-nav-btn mobile-nav-more"
                 AriaLabel="More navigation options">
            @foreach (var dest in moreItems)
            {
                @if (dest.RequiresOperatorRole)
                {
                    <AuthorizeView Roles="Admin,Operator">
                        <Authorized>
                            <MudMenuItem Icon="@dest.Icon"
                                         OnClick="() => OnDestinationSelected(dest)">
                                @dest.Label()
                            </MudMenuItem>
                        </Authorized>
                    </AuthorizeView>
                }
                else
                {
                    <MudMenuItem Icon="@dest.Icon"
                                 OnClick="() => OnDestinationSelected(dest)">
                        @dest.Label()
                    </MudMenuItem>
                }
            }
        </MudMenu>
    }
</nav>

<MudTabs @key="RenderedDestinations.Count"
         ActivePanelIndex="@_activeTabIndex"
         Class="desktop-tabs"
         ActivePanelIndexChanged="@OnActivePanelChanged"
         IconColor="Color.Inherit" Elevation="0" Rounded="true"
         TabPanelsClass="tab-shell" SliderColor="Color.Primary"
         KeepPanelsAlive="true" Centered="true">

    <MudTabPanel Icon="@LucideIcons.Eye" Text="@BrowserTabLabel">
        @if (CanShowWorkspaceContent("browser"))
        {
            <BrowserPanel/>
        }
        else if (IsSlugActive("browser"))
        {
            <ConnectionRequiredPanel />
        }
    </MudTabPanel>

    @if (TopologyService.Groups.Any())
    {
        <MudTabPanel Icon="@LucideIcons.Network" Text="@NodesTabLabel">
            <div class="tab-panel-content">
                @if (CanShowWorkspaceContent("nodes"))
                {
                    <ErrorBoundary ErrorContent="_sectionError">
                        <SparkplugNodesView />
                    </ErrorBoundary>
                }
                else if (IsSlugActive("nodes"))
                {
                    <ConnectionRequiredPanel />
                }
            </div>
        </MudTabPanel>
    }

    <MudTabPanel Icon="@LucideIcons.Activity" Text="@ChartsTabLabel">
        <div class="tab-panel-content">
            @if (CanShowWorkspaceContent("charts"))
            {
                @if (!SettingsStore.GetCharts(SessionState.SelectedConnection.Id).Any() && !SettingsStore.IsHintDismissed("charts"))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3"
                              ShowCloseIcon="true" CloseIconClicked="@(() => DismissHint("charts"))">
                        <strong>Start here:</strong> open a JSON message in Browser and choose a numeric field to create your first chart.
                    </MudAlert>
                }
                <ErrorBoundary ErrorContent="_sectionError">
                    <Charts/>
                </ErrorBoundary>
            }
            else if (IsSlugActive("charts"))
            {
                <ConnectionRequiredPanel />
            }
        </div>
    </MudTabPanel>

    <MudTabPanel Icon="@LucideIcons.Layers" Text="@SubscriptionsTabLabel">
        <div class="tab-panel-content">
            @if (CanShowWorkspaceContent("subscriptions"))
            {
                @if (!SubscriptionManager.Topics.Any() && !SettingsStore.IsHintDismissed("subscriptions"))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3"
                              ShowCloseIcon="true" CloseIconClicked="@(() => DismissHint("subscriptions"))">
                        <strong>Start here:</strong> subscribe to a topic (for example <code>#</code>) to begin collecting matching messages.
                    </MudAlert>
                }
                <ErrorBoundary ErrorContent="_sectionError">
                    <Subscriptions/>
                </ErrorBoundary>
            }
            else if (IsSlugActive("subscriptions"))
            {
                <ConnectionRequiredPanel />
            }
        </div>
    </MudTabPanel>

    <MudTabPanel Icon="@LucideIcons.Send" Text="Publish">
        <div class="tab-panel-content">
            @if (CanShowWorkspaceContent("publish"))
            {
                @if (!SettingsStore.IsHintDismissed("publish"))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3"
                              ShowCloseIcon="true" CloseIconClicked="@(() => DismissHint("publish"))">
                        <strong>Start here:</strong> set a topic and payload, then publish to verify broker writes and downstream subscribers.
                    </MudAlert>
                }
                <ErrorBoundary ErrorContent="_sectionError">
                    <AuthorizeView Roles="Admin,Operator">
                        <Authorized>
                            <Publishers/>
                        </Authorized>
                        <NotAuthorized>
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                                Operator role required to publish messages.
                            </MudAlert>
                        </NotAuthorized>
                    </AuthorizeView>
                </ErrorBoundary>
            }
            else if (IsSlugActive("publish"))
            {
                <ConnectionRequiredPanel />
            }
        </div>
    </MudTabPanel>

    <MudTabPanel Icon="@LucideIcons.Zap" Text="@EmulationTabLabel">
        <div class="tab-panel-content">
            @if (CanShowWorkspaceContent("emulation"))
            {
                @if (EmulationService.Nodes.Count == 0 && !SettingsStore.IsHintDismissed("emulation"))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3"
                              ShowCloseIcon="true" CloseIconClicked="@(() => DismissHint("emulation"))">
                        <strong>Start here:</strong> add an emulator node, then start emulation to stream synthetic metrics.
                    </MudAlert>
                }
                <ErrorBoundary ErrorContent="_sectionError">
                    <AuthorizeView Roles="Admin,Operator">
                        <Authorized>
                            <EmulationPanel/>
                        </Authorized>
                        <NotAuthorized>
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                                Operator role required to run emulations.
                            </MudAlert>
                        </NotAuthorized>
                    </AuthorizeView>
                </ErrorBoundary>
            }
            else if (IsSlugActive("emulation"))
            {
                <ConnectionRequiredPanel />
            }
        </div>
    </MudTabPanel>

    <MudTabPanel Icon="@LucideIcons.Settings" Text="Settings">
        <div class="tab-panel-content">
            <ErrorBoundary ErrorContent="_sectionError">
                <Settings/>
            </ErrorBoundary>
        </div>
    </MudTabPanel>

</MudTabs>

@code {
    private string BrowserTabLabel =>
        MessageStoreManager.MessageStores.Count > 0 ? $"Browser ({MessageStoreManager.MessageStores.Count})" : "Browser";

    private string ChartsTabLabel =>
        SettingsStore.GetCharts(SessionState.SelectedConnection.Id).Count > 0 ? $"Charts ({SettingsStore.GetCharts(SessionState.SelectedConnection.Id).Count})" : "Charts";

    private string SubscriptionsTabLabel =>
        SubscriptionManager.Topics.Count > 0 ? $"Subscriptions ({SubscriptionManager.Topics.Count})" : "Subscriptions";

    private string NodesTabLabel
    {
        get
        {
            var count = TopologyService.Groups.Values.Sum(g => g.Nodes.Count);
            return count > 0 ? $"Nodes ({count})" : "Nodes";
        }
    }

    private string EmulationTabLabel =>
        EmulationService.Nodes.Count > 0 ? $"Emulation ({EmulationService.Nodes.Count})" : "Emulation";

    private readonly RenderFragment<Exception> _sectionError = _ => @<SectionError />;

    private string _activeSlug = "browser";
    private int _activeTabIndex;
    private bool _suppressUrlUpdate;
    private Func<EventArgs, Task>? _connectionStateChangedHandler;

    private IReadOnlyList<NavigationDestination> RenderedDestinations =>
        _destinations.Where(d => d.IsVisible()).ToList();

    private void SyncActiveTabIndex()
    {
        var rendered = RenderedDestinations;
        for (int i = 0; i < rendered.Count; i++)
        {
            if (string.Equals(rendered[i].Slug, _activeSlug, StringComparison.OrdinalIgnoreCase))
            {
                _activeTabIndex = i;
                return;
            }
        }
        _activeTabIndex = 0;
    }

    private bool IsSlugActive(string slug) =>
        string.Equals(_activeSlug, slug, StringComparison.OrdinalIgnoreCase);

    private bool CanShowWorkspaceContent(string slug) =>
        MqttClient.IsConnected || !DestinationRequiresConnection(slug);

    private bool DestinationRequiresConnection(string slug)
    {
        var dest = _destinations.FirstOrDefault(d =>
            string.Equals(d.Slug, slug, StringComparison.OrdinalIgnoreCase));
        return dest?.RequiresConnection ?? true;
    }

    private sealed record NavigationDestination(
        int Index,
        string Slug,
        Func<string> Label,
        string Icon,
        bool IsMobilePrimary,
        Func<bool> IsVisible,
        bool RequiresOperatorRole = false,
        bool RequiresConnection = true);

    private IReadOnlyList<NavigationDestination> _destinations = null!;

    private IReadOnlyList<NavigationDestination> BuildDestinations() =>
    [
        new(0, "browser", () => BrowserTabLabel, LucideIcons.Eye,
            IsMobilePrimary: true, IsVisible: () => true),
        new(1, "nodes", () => NodesTabLabel, LucideIcons.Network,
            IsMobilePrimary: true, IsVisible: () => TopologyService.Groups.Any()),
        new(2, "charts", () => ChartsTabLabel, LucideIcons.Activity,
            IsMobilePrimary: true, IsVisible: () => true),
        new(3, "subscriptions", () => SubscriptionsTabLabel, LucideIcons.Layers,
            IsMobilePrimary: false, IsVisible: () => true),
        new(4, "publish", () => "Publish", LucideIcons.Send,
            IsMobilePrimary: true, IsVisible: () => true, RequiresOperatorRole: true),
        new(5, "emulation", () => EmulationTabLabel, LucideIcons.Zap,
            IsMobilePrimary: false, IsVisible: () => true, RequiresOperatorRole: true),
        new(6, "settings", () => "Settings", LucideIcons.Settings,
            IsMobilePrimary: false, IsVisible: () => true, RequiresConnection: false),
    ];

    protected override void OnInitialized()
    {
        TopologyService.TopologyChanged += OnTopologyChanged;
        _destinations = BuildDestinations();
        _activeSlug = ResolveSlugFromUrl();
        SyncActiveTabIndex();
        NavigationManager.LocationChanged += OnLocationChanged;

        _connectionStateChangedHandler = OnConnectionStateChangedAsync;
        MqttClient.ConnectionStateChangedAsync += _connectionStateChangedHandler;

        SessionLifecycle.ActiveConnectionStopped += OnActiveConnectionStopped;
    }

    private void OnTopologyChanged()
    {
        var activeDest = _destinations.FirstOrDefault(d =>
            string.Equals(d.Slug, _activeSlug, StringComparison.OrdinalIgnoreCase));
        if (activeDest is null || !activeDest.IsVisible())
            _activeSlug = "browser";
        SyncActiveTabIndex();
        InvokeAsync(StateHasChanged);
    }

    private Task OnConnectionStateChangedAsync(EventArgs args) =>
        InvokeAsync(StateHasChanged);

    private void OnActiveConnectionStopped() =>
        InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        TopologyService.TopologyChanged -= OnTopologyChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
        if (_connectionStateChangedHandler is not null)
            MqttClient.ConnectionStateChangedAsync -= _connectionStateChangedHandler;
        SessionLifecycle.ActiveConnectionStopped -= OnActiveConnectionStopped;
    }

    private async Task DismissHint(string hintId)
    {
        await SettingsStore.DismissHintAsync(hintId);
        StateHasChanged();
    }

    private string ResolveSlugFromUrl()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = uri.Query.TrimStart('?');
        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var eq = pair.IndexOf('=');
            if (eq <= 0) continue;
            var key = pair[..eq];
            if (string.Equals(key, "tab", StringComparison.OrdinalIgnoreCase))
            {
                var value = Uri.UnescapeDataString(pair[(eq + 1)..]);
                var dest = _destinations.FirstOrDefault(d =>
                    string.Equals(d.Slug, value, StringComparison.OrdinalIgnoreCase));
                if (dest is not null && dest.IsVisible()) return dest.Slug;
                return "browser";
            }
        }
        return "browser";
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_suppressUrlUpdate) return;
        var slug = ResolveSlugFromUrl();
        if (!string.Equals(slug, _activeSlug, StringComparison.OrdinalIgnoreCase))
        {
            _activeSlug = slug;
            SyncActiveTabIndex();
        }
    }

    private void OnActivePanelChanged(int physicalIndex)
    {
        var rendered = RenderedDestinations;
        if (physicalIndex < 0 || physicalIndex >= rendered.Count) return;
        var dest = rendered[physicalIndex];
        _activeSlug = dest.Slug;
        _activeTabIndex = physicalIndex;
        if (_suppressUrlUpdate) return;
        var newUrl = NavigationManager.GetUriWithQueryParameter("tab", dest.Slug);
        _suppressUrlUpdate = true;
        try { NavigationManager.NavigateTo(newUrl, forceLoad: false); }
        finally { _suppressUrlUpdate = false; }
    }

    private void OnDestinationSelected(NavigationDestination dest)
    {
        _activeSlug = dest.Slug;
        SyncActiveTabIndex();
        if (_suppressUrlUpdate) return;
        var newUrl = NavigationManager.GetUriWithQueryParameter("tab", dest.Slug);
        _suppressUrlUpdate = true;
        try { NavigationManager.NavigateTo(newUrl, forceLoad: false); }
        finally { _suppressUrlUpdate = false; }
    }
}
