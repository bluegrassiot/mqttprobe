@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop
@using MQTTnet.Extensions.ManagedClient
@using MqttProbe.Services.Configuration
@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject IManagedMqttClient MqttClient
@inject ISettingsStore SettingsStore
@inject IAppInfoService AppInfoService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JsRuntime
@inject IThemes Themes

<CascadingValue Value="Themes.IsDarkMode" Name="IsDarkMode">
<MudThemeProvider Theme="@Themes.CurrentTheme" IsDarkMode="@Themes.IsDarkMode"/>
<MudPopoverProvider/>
<MudSnackbarProvider/>
<MudDialogProvider CloseButton="true"
                   NoHeader="false"
                   FullWidth="true"
                   MaxWidth="MaxWidth.Large"/>

<MudLayout>
    <AppShellBar />

    <MudMainContent Class="pt-0">
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="@($"app-shell-container{(AppInfoService.IsNative ? " app-shell-container--native" : string.Empty)}")">
            <div class="@($"app-shell{(AppInfoService.IsNative ? " app-shell--native" : string.Empty)}")">
            <div class="app-shell-body">
                @if (MqttClient.IsConnected || _isAuthPage)
                {
                    @Body
                }
                else if (MqttClient.IsStarted)
                {
                    <MudGrid>
                        <MudItem Class="d-flex justify-center" xs="12">
                            <MudText Class="reconnect-message" Typo="Typo.h4" Align="Align.Center">
                                Disconnected — attempting to reconnect…
                            </MudText>
                        </MudItem>
                        <MudItem Class="d-flex justify-center" xs="12">
                            <img class="signal-connecting" width="104" height="104" src="/_content/MqttProbe.Shared/img/signal-motif.svg" alt="Searching for signal" />
                        </MudItem>
                        <MudItem Class="d-flex justify-center" xs="12">
                            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                       StartIcon="@LucideIcons.CircleStop"
                                       Class="reconnect-stop-btn"
                                       OnClick="@StopReconnect">Stop</MudButton>
                        </MudItem>
                    </MudGrid>
                }
            </div>
            </div>
        </MudContainer>
    </MudMainContent>
</MudLayout>
</CascadingValue>

<UpdateStartupCheck />

@code {
    private Func<EventArgs, Task>? _connectionStateChangedHandler;
    private bool _disposed;
    private bool _isAuthPage;
    private bool _hasRendered;

    protected override void OnInitialized()
    {
        Themes.ModeChanged += OnModeChanged;
        Themes.FontModeChanged += OnFontModeChanged;
        SettingsStore.UiPreferencesChanged += OnUiPreferencesChangedFromStore;
        UpdateAuthPageState();
        NavigationManager.LocationChanged += OnLocationChanged;

        _connectionStateChangedHandler = OnConnectionStateChangedAsync;
        MqttClient.ConnectionStateChangedAsync += _connectionStateChangedHandler;

        Themes.SetFontAccessible(SettingsStore.Config.Ui.FontAccessible);

        var savedTheme = SettingsStore.Config.Ui.Theme;
        Themes.SetTheme(!string.Equals(savedTheme, "light", StringComparison.OrdinalIgnoreCase));
    }

    private void OnModeChanged()
    {
        _ = SettingsStore.SetThemeAsync(Themes.IsDarkMode ? "dark" : "light");
        InvokeAsync(StateHasChanged);
    }

    private void OnFontModeChanged()
    {
        _ = SettingsStore.SetFontAccessibleAsync(Themes.IsFontAccessible);
        if (_hasRendered)
            _ = SetBodyFontClass();
        InvokeAsync(StateHasChanged);
    }

    private void OnUiPreferencesChangedFromStore()
    {
        var cfg = SettingsStore.Config.Ui;
        Themes.SetFontAccessible(cfg.FontAccessible);
        Themes.SetTheme(!string.Equals(cfg.Theme, "light", StringComparison.OrdinalIgnoreCase));
        InvokeAsync(StateHasChanged);
    }

    private async Task SetBodyFontClass() =>
        await JsRuntime.InvokeVoidAsync(
            "eval",
            $"document.body.classList.toggle('font-accessible', {Themes.IsFontAccessible.ToString().ToLowerInvariant()});");

    private Task OnConnectionStateChangedAsync(EventArgs args)
    {
        if (!_disposed)
            return InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;
            await SetBodyFontClass();
        }
    }

    private async Task StopReconnect()
    {
        try
        {
            await MqttClient.StopAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to stop the connection: {ex.Message}", Severity.Error);
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateAuthPageState();
        InvokeAsync(StateHasChanged);
    }

    private static readonly string[] AuthPageRoutes = ["change-password"];

    private void UpdateAuthPageState()
    {
        var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimStart('/');
        _isAuthPage = AuthPageRoutes.Any(route => path.StartsWith(route, StringComparison.OrdinalIgnoreCase));
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;
        Themes.ModeChanged -= OnModeChanged;
        Themes.FontModeChanged -= OnFontModeChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
        SettingsStore.UiPreferencesChanged -= OnUiPreferencesChangedFromStore;
        if (_connectionStateChangedHandler is not null)
            MqttClient.ConnectionStateChangedAsync -= _connectionStateChangedHandler;
        return ValueTask.CompletedTask;
    }
}
