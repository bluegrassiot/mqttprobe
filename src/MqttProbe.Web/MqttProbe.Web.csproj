<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RootNamespace>MqttProbe.Web</RootNamespace>
        <Version>1.0.0</Version>
        <!-- CS8669: Razor source generator emits nullable annotations without #nullable directives; suppress on generated files only -->
        <NoWarn>$(NoWarn);CS8669</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Release'">
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="CurrieTechnologies.Razor.Clipboard" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\MqttProbe.Shared\MqttProbe.Shared.csproj" />
    </ItemGroup>

    <ItemGroup>
      <Content Update="wwwroot\favicon.svg">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

</Project>
