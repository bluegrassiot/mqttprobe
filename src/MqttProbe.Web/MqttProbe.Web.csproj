<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RootNamespace>MqttProbe.Web</RootNamespace>
        <Version>0.0.0</Version>
        <!-- CS8669: Razor source generator emits nullable annotations without #nullable directives; suppress on generated files only -->
        <NoWarn>$(NoWarn);CS8669</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Release'">
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    </PropertyGroup>

    <PropertyGroup>
        <DefaultLanguage>en-US</DefaultLanguage>
    </PropertyGroup>

    <ItemGroup>
      <ProjectReference Include="..\MqttProbe.Shared\MqttProbe.Shared.csproj" />
    </ItemGroup>

    <ItemGroup>
      <Content Update="wwwroot\favicon.svg">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

    <!-- Runtime-generated config — never publish credentials or key material -->
    <ItemGroup>
      <Content Remove="Config\appsettings.json" />
      <Content Remove="Config\secrets.dat" />
      <Content Remove="Config\dp-keys\**" />
      <None Include="Config\appsettings.json" />
      <None Include="Config\secrets.dat" />
      <None Include="Config\dp-keys\**" />
    </ItemGroup>

</Project>
