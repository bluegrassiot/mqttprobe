@inject NavigationManager NavigationManager

<MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="ma-2" role="alert">
    <div class="d-flex align-center gap-3 flex-wrap">
        <span>Something went wrong displaying this section.</span>
        <AppDestructiveButton Size="Size.Small"
                   StartIcon="@LucideIcons.RefreshCw" OnClick="Reload">
            Reload
        </AppDestructiveButton>
    </div>
</MudAlert>

@code {
    private void Reload() => NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
}
