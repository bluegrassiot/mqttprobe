@using Microsoft.Extensions.DependencyInjection
@using MqttProbe.Services.Security
@inject IServiceProvider Services

@if (_show)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined"
              Class="ma-2 secret-protection-banner" role="status">
        Secure operating-system key storage is unavailable. Secrets are protected using a local key file and may be recoverable by anyone who can copy the application data directory.
    </MudAlert>
}

@code {
    private bool _show;

    protected override void OnInitialized()
    {
        var status = Services.GetService<ISecretProtectionStatus>();
        if (status is null) return;
        try
        {
            _show = status.Mode == SecretProtectionMode.FileFallback;
        }
        catch (InvalidOperationException)
        {
            _show = false;
        }
    }
}