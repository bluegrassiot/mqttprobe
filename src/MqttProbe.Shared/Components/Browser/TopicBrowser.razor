@inject IMessageStoreManager MessageStoreManagerService
@inject ILogger<TopicBrowser> Logger
@using Microsoft.Extensions.Logging
@implements IAsyncDisposable

<MudPaper Elevation="1" Class="pa-2 app-chrome-panel" Style="height:100%; display:flex; flex-direction:column; overflow:hidden; box-sizing:border-box;">
    <div class="topic-header-row">
        <MudIcon Icon="@LucideIcons.Layers" Size="Size.Small" Color="Color.Primary"/>
        <MudText Typo="Typo.subtitle2" Style="font-weight:600">Topics</MudText>
        @if (MessageStoreManagerService.MessageStores.Any())
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                     Style="height:20px; font-size:0.7rem; padding:0 6px;">
                @MessageStoreManagerService.MessageStores.Count
            </MudChip>
        }
    </div>
    <div class="topic-filter-wrap">
        <MudTextField @bind-Value="_searchFilter" Placeholder="Filter…"
                      Adornment="Adornment.Start" AdornmentIcon="@LucideIcons.Search"
                      Immediate="true" Clearable="true" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="topic-filter-field"/>
    </div>

    <div class="topic-tree-wrap" style="flex:1; overflow-y:auto; min-height:0;">
        @if (FilteredStores.Any())
        {
            <MudTreeView SelectedValue="@MessageStoreManagerService.SelectedMessageStore"
                         SelectedValueChanged="OnTopicSelected" T="MessageStore" Dense="true">
                @foreach (var msgStore in FilteredStores)
                {
                    <RecursiveTree @key="@msgStore.Value.FullTopic" MessageStore="@msgStore.Value" Filter="@_searchFilter"
                                   ExpandFirstLevel="true"/>
                }
            </MudTreeView>
        }
        else if (MessageStoreManagerService.MessageStores.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-3">
                No topics match "@_searchFilter"
            </MudText>
        }
        else
        {
            <div class="d-flex flex-column align-center pa-6 topic-empty">
                <MudIcon Icon="@LucideIcons.Inbox" Size="Size.Large" Color="Color.Secondary"/>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">No messages received yet</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Press play to start capturing</MudText>
            </div>
        }
    </div>
</MudPaper>

@code {
    private string? _searchFilter;
    private Timer? _updateTimer;
    private bool _disposed;
    private int _lastTopicCount;
    private int _lastTotalNodeCount;
    private int _lastTotalMessageCount;

    private IEnumerable<KeyValuePair<string, MessageStore>> FilteredStores =>
        string.IsNullOrWhiteSpace(_searchFilter)
            ? MessageStoreManagerService.MessageStores
            : MessageStoreManagerService.MessageStores
                .Where(s => RecursiveTree.Matches(s.Value, _searchFilter));

    protected override void OnInitialized()
    {
        _lastTopicCount = 0;
        _lastTotalNodeCount = 0;
        _lastTotalMessageCount = 0;
        _updateTimer = new Timer(_ =>
        {
            if (_disposed) return;
            var topicCount = MessageStoreManagerService.MessageStores.Count;
            var totalNodes = MessageStoreManagerService.MessageStores.Values
                .Sum(CountNodesRecursive);
            var totalMessages = MessageStoreManagerService.MessageStores.Values
                .Sum(CountMessagesRecursive);
            if (topicCount == _lastTopicCount
                && totalNodes == _lastTotalNodeCount
                && totalMessages == _lastTotalMessageCount) return;
            _lastTopicCount = topicCount;
            _lastTotalNodeCount = totalNodes;
            _lastTotalMessageCount = totalMessages;
#pragma warning disable CS4014 // Intentional fire-and-forget from Timer callback
            RequestRenderSafelyAsync();
#pragma warning restore CS4014
        }, null, 0, 1_000);
    }

    private async Task RequestRenderSafelyAsync()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException) when (_disposed)
        {
            // The circuit was torn down between the timer tick and the dispatch; nothing to render.
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "TopicBrowser timer render update failed");
        }
    }

    private void OnTopicSelected(MessageStore? store)
    {
        MessageStoreManagerService.SelectedMessageStore = store;
    }

    private static int CountNodesRecursive(MessageStore store)
    {
        var count = 1;
        if (store.SubTopics == null) return count;
        foreach (var sub in store.SubTopics.Values)
            count += CountNodesRecursive(sub);
        return count;
    }

    private static int CountMessagesRecursive(MessageStore store)
    {
        var count = store.Messages?.Count ?? 0;
        if (store.SubTopics == null) return count;
        foreach (var sub in store.SubTopics.Values)
            count += CountMessagesRecursive(sub);
        return count;
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_updateTimer != null)
            await _updateTimer.DisposeAsync();
    }
}
