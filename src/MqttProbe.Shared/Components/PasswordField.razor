@using MqttProbe.Models
<MudTextField @bind-Value="Connection.Password" InputType="@_passwordInput" Adornment="Adornment.End" AdornmentIcon="@_passwordInputIcon"
              OnAdornmentClick="ToggleShowPassword" AdornmentAriaLabel="Show Password" Variant="Variant.Outlined"
              For="@(() => Connection.Password)"
              Immediate="true"
              Label="Password"/>

@code {
    [Parameter, EditorRequired] public required Connection Connection { get; set; }

    private bool _showPassword;
    private InputType _passwordInput = InputType.Password;
    private string _passwordInputIcon = LucideIcons.EyeOff;

    private void ToggleShowPassword()
    {
        _showPassword = !_showPassword;
        _passwordInputIcon = _showPassword ? LucideIcons.Eye : LucideIcons.EyeOff;
        _passwordInput = _showPassword ? InputType.Text : InputType.Password;
    }

}