@using MqttProbe.Services.Configuration
@inject IMessageStoreManager MessageStoreManager
@inject ISettingsStore SettingsStore
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<TabPanelHeader Title="Browser" Icon="@LucideIcons.Eye">
    <HeaderChips>
        @if (MessageStoreManager.MessageStores.Any())
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                     Style="height:20px; font-size:0.7rem; padding:0 6px;">
                @MessageStoreManager.MessageStores.Count
            </MudChip>
        }
    </HeaderChips>
    <HeaderActions>
        <MudButton Variant="Variant.Outlined" Size="Size.Medium"
                   StartIcon="@LucideIcons.Trash2"
                   Color="Color.Error" Class="app-btn-min"
                   OnClick="ClearAllMessages">
            Clear Messages
        </MudButton>
    </HeaderActions>
</TabPanelHeader>
<div class="tab-panel-content">
    @if (!MessageStoreManager.MessageStores.Any() && !SettingsStore.IsHintDismissed("browser"))
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-2"
                  ShowCloseIcon="true" CloseIconClicked="@DismissHint">
            <strong>Start here:</strong> connect to a broker, then select or add subscriptions to begin receiving topics.
        </MudAlert>
    }
    <ErrorBoundary ErrorContent="_sectionError">
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <div class="browser-split-wrap">
                <MudSplitPanel Class="browser-split-panel"
                               FirstPanelInitialSize="320" MinPanelSize="220"
                               PanelGap="6" ResetOnDoubleClick="true" Transparent="true">
                    <FirstPanel>
                        <TopicBrowser/>
                    </FirstPanel>
                    <SecondPanel>
                        <PayloadBrowser/>
                    </SecondPanel>
                </MudSplitPanel>
            </div>
        </MudHidden>
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <div class="browser-split-wrap">
                <MudSplitPanel Class="browser-split-panel" Horizontal="true"
                               FirstPanelInitialSize="260" MinPanelSize="120"
                               PanelGap="6" ResetOnDoubleClick="true" Transparent="true">
                    <FirstPanel>
                        <TopicBrowser/>
                    </FirstPanel>
                    <SecondPanel>
                        <PayloadBrowser/>
                    </SecondPanel>
                </MudSplitPanel>
            </div>
        </MudHidden>
    </ErrorBoundary>
</div>

@code {
    private readonly RenderFragment<Exception> _sectionError = _ => @<SectionError />;

    private async Task ClearAllMessages()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Clear All Messages",
            "This will remove all stored topics and messages. Continue?",
            yesText: "Clear all", cancelText: "Cancel",
            options: new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        if (confirmed != true)
            return;

        await MessageStoreManager.ClearAllMessages();
        Snackbar.Add("All stored messages cleared.", Severity.Success);
    }

    private async Task DismissHint()
    {
        await SettingsStore.DismissHintAsync("browser");
        StateHasChanged();
    }
}
