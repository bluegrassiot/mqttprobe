@using Microsoft.JSInterop
@using MqttProbe.Services.Configuration
@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject ISettingsStore SettingsStore
@inject IAppInfoService AppInfoService
@inject IJSRuntime JsRuntime
@inject IThemes Themes

<CascadingValue Value="Themes.IsDarkMode" Name="IsDarkMode">
<MudThemeProvider Theme="@Themes.CurrentTheme" IsDarkMode="@Themes.IsDarkMode"/>
<MudPopoverProvider/>
<MudSnackbarProvider/>
<MudDialogProvider CloseButton="true"
                   NoHeader="false"
                   FullWidth="true"
                   MaxWidth="MaxWidth.Large"/>

<MudLayout>
    <AppShellBar />

    <MudMainContent Class="pt-0">
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="@($"app-shell-container{(AppInfoService.IsNative ? " app-shell-container--native" : string.Empty)}")">
            <div class="@($"app-shell{(AppInfoService.IsNative ? " app-shell--native" : string.Empty)}")">
            <div class="app-shell-body">
                @Body
            </div>
            </div>
        </MudContainer>
    </MudMainContent>
</MudLayout>
</CascadingValue>

<UpdateStartupCheck />

@code {
    private bool _hasRendered;

    protected override void OnInitialized()
    {
        Themes.ModeChanged += OnModeChanged;
        Themes.FontModeChanged += OnFontModeChanged;
        SettingsStore.UiPreferencesChanged += OnUiPreferencesChangedFromStore;

        Themes.SetFontAccessible(SettingsStore.Config.Ui.FontAccessible);

        var savedTheme = SettingsStore.Config.Ui.Theme;
        Themes.SetTheme(!string.Equals(savedTheme, "light", StringComparison.OrdinalIgnoreCase));
    }

    private void OnModeChanged()
    {
        _ = SettingsStore.SetThemeAsync(Themes.IsDarkMode ? "dark" : "light");
        InvokeAsync(StateHasChanged);
    }

    private void OnFontModeChanged()
    {
        _ = SettingsStore.SetFontAccessibleAsync(Themes.IsFontAccessible);
        if (_hasRendered)
            _ = SetBodyFontClass();
        InvokeAsync(StateHasChanged);
    }

    private void OnUiPreferencesChangedFromStore()
    {
        var cfg = SettingsStore.Config.Ui;
        Themes.SetFontAccessible(cfg.FontAccessible);
        Themes.SetTheme(!string.Equals(cfg.Theme, "light", StringComparison.OrdinalIgnoreCase));
        InvokeAsync(StateHasChanged);
    }

    private async Task SetBodyFontClass() =>
        await JsRuntime.InvokeVoidAsync(
            "eval",
            $"document.body.classList.toggle('font-accessible', {Themes.IsFontAccessible.ToString().ToLowerInvariant()});");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;
            await SetBodyFontClass();
        }
    }

    public ValueTask DisposeAsync()
    {
        Themes.ModeChanged -= OnModeChanged;
        Themes.FontModeChanged -= OnFontModeChanged;
        SettingsStore.UiPreferencesChanged -= OnUiPreferencesChangedFromStore;
        return ValueTask.CompletedTask;
    }
}
