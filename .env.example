# Copy to .env and set the hostname or IP that browsers on other machines
# use to reach MQTT Probe. It drives both the TLS certificate (caddy) and
# host filtering (AllowedHosts) — a mismatch produces 400 Bad Request.
# Examples:
#   MQTTPROBE_HOST=192.168.1.50
#   MQTTPROBE_HOST=mqttprobe.lan
MQTTPROBE_HOST=localhost
