{
  "AllowedHosts": "mqttprobe.example.com;localhost",
  "ForwardedHeaders": {
    "ForwardLimit": 1,
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ],
    "KnownNetworks": []
  },
  "Connections": [
    {
      "Name": "My Broker",
      "Host": "192.168.1.100",
      "Port": 1883,
      "User": "admin",
      "Password": "<your-broker-password>",
      "Protocol": 0,
      "ClientId": "mqtt-probe-client",
      "WebsocketBasePath": "mqtt",
      "UseTls": false,
      "AllowUntrustedCertificate": false,
      "SubscribedTopics": []
    }
  ],
  "Auth": {
    "Username": "admin",
    "PasswordHash": "<generated at first run — see console output>"
  },
  "Performance": {
    "MaxStoredMessages": 10000,
    "MaxMessagesPerSecond": 50000
  },
  "Ui": {
    "FontAccessible": false,
    "Theme": "dark",
    "FontFamily": "Inter",
    "AutoResubscribe": true,
    "DismissedHints": []
  },
  "Charts": [],
  "Emulators": {
    "Version": 1,
    "PublishIntervalMs": 500,
    "Nodes": []
  }
}
