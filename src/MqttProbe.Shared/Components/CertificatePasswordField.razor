@using MudBlazor

<MudTextField T="string"
              Value="@Value"
              ValueChanged="@ValueChanged"
              Label="@Label"
              Variant="@Variant"
              InputType="@_inputType"
              Adornment="Adornment.End"
              AdornmentIcon="@_passwordInputIcon"
              OnAdornmentClick="@ToggleVisibility"
              AdornmentAriaLabel="Show Password"
              Immediate="true"
              Required="@Required"
              Class="@Class" />

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Password";
    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;
    [Parameter] public bool Required { get; set; }
    [Parameter] public string? Class { get; set; }

    private bool _showPassword;
    private InputType _inputType = InputType.Password;
    private string _passwordInputIcon = LucideIcons.EyeOff;

    private void ToggleVisibility()
    {
        _showPassword = !_showPassword;
        _passwordInputIcon = _showPassword ? LucideIcons.Eye : LucideIcons.EyeOff;
        _inputType = _showPassword ? InputType.Text : InputType.Password;
    }
}
