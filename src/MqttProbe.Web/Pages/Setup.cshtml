@page
@model MqttProbe.Pages.SetupModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MQTTProbe — Setup</title>
    <link href="/_content/MqttProbe.Shared/css/fonts.css" rel="stylesheet" />
    <link href="/_content/MqttProbe.Shared/css/auth-layout.css" rel="stylesheet" />
</head>
<body>
<div class="auth-card">
    <h1><span class="brand-mqtt">MQTT</span><span class="brand-probe">Probe</span></h1>
    <p class="subtitle">Create your login credentials to get started.</p>
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error">@Model.ErrorMessage</div>
    }
    <form method="post">
        <label for="username">Username</label>
        <div class="field">
            <input type="text" id="username" name="username" value="admin" autocomplete="username" required autofocus />
        </div>

        <label for="password">Password</label>
        <div class="field password-wrapper">
            <input type="password" id="password" name="password" autocomplete="new-password" required />
            <button type="button" class="password-toggle" onclick="togglePassword('password', this)"
                    aria-label="Show password" aria-controls="password">
                <svg class="icon-eye-off" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
                <svg class="icon-eye" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" style="display:none">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                </svg>
            </button>
        </div>

        <label for="confirmPassword">Confirm Password</label>
        <div class="field password-wrapper">
            <input type="password" id="confirmPassword" name="confirmPassword" autocomplete="new-password" required />
            <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword', this)"
                    aria-label="Show confirm password" aria-controls="confirmPassword">
                <svg class="icon-eye-off" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
                <svg class="icon-eye" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" style="display:none">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                </svg>
            </button>
        </div>

        @Html.AntiForgeryToken()
        <button type="submit">Create Account</button>
    </form>
</div>
<script>
    function togglePassword(inputId, btn) {
        var input = document.getElementById(inputId);
        var eyeOff = btn.querySelector('.icon-eye-off');
        var eye = btn.querySelector('.icon-eye');
        var showing = input.type === 'text';
        input.type = showing ? 'password' : 'text';
        eye.style.display = showing ? 'none' : 'block';
        eyeOff.style.display = showing ? 'block' : 'none';
        btn.setAttribute('aria-label', showing ? 'Show password' : 'Hide password');
    }
</script>
</body>
</html>
